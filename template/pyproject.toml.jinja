[project]
name = "{{ package_name }}"
dynamic = ["version"]
description = "{{ description }}"
readme = "README.md"
maintainers = [
    { name = "{{ author_name }}", email = "{{ author_email }}" }
]
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" }
]
license = { text = "{{ license }}" }
requires-python = ">={{ min_python_version }}"
classifiers = [
    "Development Status :: 3 - Alpha",
    "Intended Audience :: Developers",
    "Programming Language :: Python :: 3 :: Only",
{%- set versions = ["3.11", "3.12", "3.13", "3.14"] %}
{%- for v in versions if v >= min_python_version and v <= max_python_version %}
    "Programming Language :: Python :: {{ v }}",
{%- endfor %}
]
dependencies = [
{% if include_examples %}
    "numpy>=2.3.0",
    "pandas>=2.2.0",
    "plotly>=6.5.0",
{% endif %}
]

[dependency-groups]
dev = [
    {include-group = "tests"},
    {include-group = "lint"},
    {include-group = "docs"},
    {include-group = "fix"},
{% if include_examples %}    {include-group = "examples"},
{% endif %}
]
tests = [
    "pytest>=8.3",
    "pytest-cov>=7.0",
    "pytest-mock>=3.14",
    "pytest-xdist>=3.8",
    "covdefaults>=2.3",
    "hypothesis>=6.100",
]
lint = [
    "interrogate>=1.7.0",
    "ruff>=0.8.0",
    "rumdl>=0.1.33",
    "ty>=0.0.12",
]
docs = [
    # Griffe is imported directly by docs_build/_api_pages.py to discover the package's
    # public surface -- the same analysis mkdocstrings renders the API pages from,
    # so the two cannot disagree about what is public. Declaring it records a
    # dependency that is real: relying on it arriving transitively is how a future
    # mkdocstrings release breaks every generated project at once.
    #
    # It is NOT free, contrary to what this comment claimed until a fan-out
    # measured it. Griffe 2.x is split across three distributions and
    # mkdocstrings[python] pulls only `griffelib`, which is what actually provides
    # the `griffe` module. Declaring `griffe` therefore adds two packages the docs
    # build does not use -- the `griffe` metapackage and `griffecli` (~15 KB total).
    # Kept anyway, and the reason is a file collision, not taste. `griffe` 1.x
    # OWNS the `griffe/` module directory; `griffelib` 2.x provides that same
    # path. Naming `griffelib` in a project whose mkdocstrings still resolves to
    # the 1.x line would install two distributions owning one import path.
    # Depending on `griffe` cannot do that: it resolves either to 1.x, which owns
    # the module, or to the 2.x metapackage, which defers to griffelib. Exactly
    # one distribution owns `griffe/` in both cases, and ~15 KB is a cheap price
    # for that.
    #
    # Deliberately NOT pinned tighter than mkdocstrings pins it (`>=1.13`): two
    # floors on one package is a resolver conflict waiting for a release.
    "griffe>=1.0",
    "mkdocs>=1.6.0",
    "mkdocs-autorefs>=1.0",
    "mkdocs-material>=9.7",
    "mkdocstrings[python]>=0.26.0",
    # The documentation engine. Zensical is the maintained successor to Material
    # for MkDocs (which reaches a hard EOL on 2026-11-05); it reads this project's
    # mkdocs.yml natively and forwards the API reference to the real mkdocstrings
    # package. `mkdocs`/`mkdocs-material` above are kept so CI can still run a
    # MkDocs build as a comparison during the engine transition.
    "zensical>=0.0.51",
    # Zensical requires pymdown-extensions 11+, so the whole markdown-extension
    # config is exercised under that major; mkdocs-material 9.7 accepts it too, so
    # both engines resolve to the same pymdownx. A changed extension default is a
    # silent content regression, so this is pinned to the major, not left to drift.
    "pymdown-extensions>=11.0.1",
    # Also a direct import of docs_build/_api_pages.py, which reads mkdocstrings'
    # `preload_modules` out of mkdocs.yml so that list has one definition rather
    # than two. Same argument as griffe above: it arrives via mkdocs anyway, but
    # relying on a transitive dependency is how a future release breaks this.
    "pyyaml>=6.0",
    # Imported by docs_build/serve.py to watch src/ and regenerate the API pages
    # during a live preview, so a new class appears without a restart. mkdocs
    # already pulls watchdog transitively (its livereload uses it), so declaring
    # it adds no install today -- but the preview watcher must keep working when
    # the engine changes to one that does not bundle it, and an explicit
    # declaration is what survives that. Same reasoning as griffe/pyyaml above.
    "watchdog>=4.0",
]
fix = [
  # prek runs the hooks. Pinned here, never invoked via `uvx`: prek substitutes its
  # own Rust implementations for the `repo: builtin` hooks, so an unpinned prek would
  # mean unpinned hook code -- exactly what the config comment below rules out.
  "prek>=0.4.10",
]
{% if include_examples %}examples = [
    "marimo>=0.19.0",
]{% endif %}

[project.urls]
Homepage = "https://github.com/{{ github_username }}/{{ project_slug }}"
Documentation = "https://{{ project_slug }}.readthedocs.io"
Repository = "https://github.com/{{ github_username }}/{{ project_slug }}"
"Bug Tracker" = "https://github.com/{{ github_username }}/{{ project_slug }}/issues"

[build-system]
requires = ["hatchling", "hatch-vcs"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]
# Puts the repo root AND src/ on the EDITABLE install's sys.path (dev mode only,
# nothing changes in the wheel). The repo root is the loading gate for
# `docs_build/`-local markdown extensions: mkdocs and its successor load
# `markdown_extensions` by module name at config time, before any hook runs, when
# `docs_build/` is not otherwise importable -- with this, `docs_build._markers`
# loads on a plain `mkdocs build` with no PYTHONPATH.
#
# `src` is NOT optional here: naming `dev-mode-dirs` at all REPLACES hatchling's
# default editable path (which was `src/`), so listing only `["."]` silently stops
# exposing the package itself -- `import {{ package_name }}` then fails, which a
# notebook cell (`from {{ package_name }}... import ...`) and any runtime import
# hit at build time, while a `--strict` docs build stays green because mkdocstrings
# reads the source via `paths: [src]`, not by importing. Both dirs, always.
dev-mode-dirs = [".", "src"]

[tool.hatch.version]
source = "vcs"
fallback-version = "0.0.0"

[tool.hatch.build.hooks.vcs]
version-file = "src/{{ package_name }}/_version.py"

[tool.ruff]
line-length = 120
target-version = "py{{ min_python_version.replace('.', '') }}"
src = ["src", "tests"]
show-fixes = true
exclude = ["src/{{ package_name }}/_version.py"{% if include_examples %}, "examples/"{% endif %}]

[tool.ruff.format]
preview = true
docstring-code-format = true
docstring-code-line-length = 100

[tool.ruff.lint]
select = [
    "E",   # pycodestyle errors
    "W",   # pycodestyle warnings
    "F",   # pyflakes
    "I",   # isort
    "B",   # flake8-bugbear
    "C4",  # flake8-comprehensions
    "UP",  # pyupgrade
    "ARG", # flake8-unused-arguments
    "SIM", # flake8-simplify
    "PL",  # Pylint
    "T10", # flake8-debugger
    "T201", # Print statement
]
ignore = [
    "E203",   # space before : (needed for how black formats slicing)
    "E501",   # line too long (handled by formatter)
    "B008",   # do not perform function calls in argument defaults
    "PLC0415", # import not at top-level (lazy imports are intentional, e.g. docs hooks)
    "PLR0913", # too many args in func def
    "PLR0915", # too many statements
    "PLR0912", # too many branches
    "PLR2004", # magic value used in comparison
]

[tool.ruff.lint.per-file-ignores]
"tests/**/*" = ["ARG", "S101", "T201", "PLR2004"]  # Allow assert statements, prints, and magic values in tests
# The template's documentation build tooling lives in docs_build/. Every script
# there prints build progress and may hold per-build caches.
#
# Deliberately `docs_build/*.py`, NOT `docs_build/_*.py`: the narrower glob would
# silently drop coverage for any un-underscored script, which is the failure
# shape this fleet specialises in. The pattern matches what the directory is for.
"docs_build/*.py" = ["T201", "PLW0603"]  # Allow prints and per-build cache globals in every build script
# `docs/*.py` is kept too, for a project's OWN scripts under docs/ (yohou has
# docs/precache_datasets.py) -- the template ships none there any more, but a
# project script prints progress the same way and should not lose its exemption.
"docs/*.py" = ["T201", "PLW0603"]

[tool.ruff.lint.isort]
known-first-party = ["{{ package_name }}"]

[tool.interrogate]
ignore-init-method = true
ignore-init-module = true
ignore-magic = false
ignore-semiprivate = false
ignore-private = false
ignore-property-decorators = false
ignore-module = false
ignore-nested-functions = false
ignore-nested-classes = true
ignore-setters = false
fail-under = 75
exclude = ["setup.py", "docs", "docs_build", "build", "tests", "*_version.py"]
ignore-regex = ["^get$", "^mock_.*", ".*BaseClass.*"]
verbose = 0
quiet = false
whitelist-regex = []
color = true
omit-covered-files = false

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = [
    "--strict-markers",
    "--strict-config",
    "--color=yes",
    "--cov={{ package_name }}",
    "--cov-report=term-missing:skip-covered",
    "--cov-report=html",
    "--cov-report=xml",
]
markers = [
    "integration: marks tests as integration tests that run subprocesses (deselect with '-m \"not integration\"')",
    "slow: marks tests as slow (deselect with '-m \"not slow\"')",{% if include_examples %}
    "example: marks tests for example notebooks (deselect with '-m \"not example\"')",{% endif %}
]

[tool.coverage.paths]
source = ["src/{{ package_name }}"]

[tool.coverage.run]
source = ["{{ package_name }}"]
branch = true
parallel = true
sigterm = true
concurrency = ["multiprocessing"]
plugins = ["covdefaults"]
omit = [
    "*/tests/*",
    "*/__pycache__/*",
    "*/_version.py",
]

[tool.coverage.report]
precision = 2
show_missing = true
skip_covered = false
fail_under = 1
include_namespace_packages = true

[tool.coverage.html]

[tool.rumdl]
flavor = "mkdocs"
line-length = 120
disable = [
    "MD012",  # Multiple consecutive blank lines (common in generated content)
    "MD013",  # Line length (handled by formatter, many long URLs/tables)
    "MD022",  # Heading blank lines (varies by document style)
    "MD031",  # No blank line before fenced code block
    "MD032",  # List should be preceded by blank line
    "MD033",  # Inline HTML (needed for README logo, MkDocs grid cards)
    "MD034",  # URL/email without angle brackets
    "MD045",  # Image missing alt text (logos use empty alt intentionally)
    "MD046",  # Code block style (indented blocks required inside MkDocs tabs)
    "MD051",  # Link fragments (cross-doc references resolved at MkDocs build time)
]
exclude = ["CHANGELOG.md", "site", "htmlcov", ".nox", ".venv", "openspec"]

[tool.rumdl.per-file-ignores]
".claude/skills/**" = ["MD007"]  # Nested lists in skill files use variable indent
".github/PULL_REQUEST_TEMPLATE.md" = ["MD041"]  # PR template starts with checklist
".github/skills/**" = ["MD007"]  # Nested lists in skill files use variable indent
"README.md" = ["MD041"]  # README starts with logo, not heading
# The page is a bare `--8<--` include; the included CHANGELOG.md supplies the
# H1. Adding one here would render two H1s and, because Material's ToC takes
# first.children when the first heading is level 1, an empty ToC on the one
# page that most needs one.
"docs/pages/reference/changelog.md" = ["MD041"]
"docs/index.md" = ["MD041"]  # Landing page starts with logo, not heading
"CONTRIBUTING.md" = ["MD057"]  # Relative link to docs/ is valid at project level
{% if include_actions %}

[tool.commitizen]
name = "cz_conventional_commits"
version_scheme = "semver"
version_provider = "scm"
update_changelog_on_bump = false
major_version_zero = true
tag_format = "v$version"
{% endif -%}
